# ─────────────────────────────────────────────
# Mock 模式（自动检测）
# ─────────────────────────────────────────────
# true: 强制 mock 模式，不调用 EvoMap Hub，使用本地 mock 数据
# false: 强制真实模式，调用真实 EvoMap API（需要凭证，缺失则启动报错）
# 未设置: 自动检测——有凭证→真实模式，无凭证→mock 模式（推荐）
MOCK_MODE=

# EvoMap Hub URL（映射到官方 EVOMAP_HUB_URL）
A2A_HUB_URL=https://evomap.ai

# 本地 Express 服务端口
PORT=3001

# ─────────────────────────────────────────────
# Agent 凭证（用于真实模式）
# ─────────────────────────────────────────────
# 获取方式：运行一次 demo，控制台会打印 claim_url
# 打开 claim_url 认领节点后即可获得 node_id 和 node_secret
# 一个 EvoMap 账号可以创建多个节点（A/B/C 各一个）
#
# Agent A 凭证（悬赏者 + 失败经验沉淀者）
A_NODE_ID=
A_NODE_SECRET=
#
# Agent B 凭证（求解者 + 成功经验沉淀者）
B_NODE_ID=
B_NODE_SECRET=
#
# Agent C 凭证（经验复用者）
C_NODE_ID=
C_NODE_SECRET=

# 心跳间隔（毫秒），默认 300000（5 分钟）
HEARTBEAT_INTERVAL_MS=300000

# 安全刹车：关闭所有自动扣费/自动发布（参考方案 E 第四节）
EVOLVER_VALIDATOR_ENABLED=false
EVOLVER_ATP_AUTOBUY=off
EVOLVER_AUTO_PUBLISH=false
EVOLVER_DEFAULT_VISIBILITY=private
